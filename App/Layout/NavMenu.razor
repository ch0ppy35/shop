<MudNavMenu>
    <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="ml-4 my-3">NAVIGATION</MudText>

    <MudNavLink Href="" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">Home</MudNavLink>

    <MudNavLink Href="products" Icon="@Icons.Material.Filled.Inventory">Products</MudNavLink>

    <MudNavLink Href="cart" Icon="@Icons.Material.Filled.ShoppingCart">
        Cart
        @if (cartItemCount > 0)
        {
            <MudBadge Color="Color.Primary" Content="@cartItemCount" Overlap="true" Class="ml-2">
                <MudIcon Icon="@Icons.Material.Filled.ShoppingCart" />
            </MudBadge>
        }
    </MudNavLink>

    <MudNavLink Href="admin/products" Icon="@Icons.Material.Filled.Settings">Admin</MudNavLink>

    <MudNavLink Href="about" Icon="@Icons.Material.Filled.Info">About</MudNavLink>
</MudNavMenu>

@code {
    private int cartItemCount = 0;

    [Inject]
    private ICartService CartService { get; set; } = default!;

    [Inject]
    private IJSRuntime JSRuntime { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        await UpdateCartItemCount();

#if !TEST
        // Listen for cart updates - skip in test environment
        try
        {
            await JSRuntime.InvokeVoidAsync("eval",
            "document.addEventListener('cartUpdated', function() { DotNet.invokeMethodAsync('Frontend', 'RefreshNavMenu'); });");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error setting up cart update listener: {ex.Message}");
        }
#endif
    }

    [JSInvokable]
    public static async Task RefreshNavMenu()
    {
        if (NavMenuInstance != null)
        {
            await NavMenuInstance.UpdateCartItemCount();
        }
    }

    private static NavMenu? NavMenuInstance;

    protected override void OnInitialized()
    {
        NavMenuInstance = this;
    }

    private async Task UpdateCartItemCount()
    {
        var cart = await CartService.GetCartAsync();
        cartItemCount = cart.ItemCount;
        StateHasChanged();
    }


}
