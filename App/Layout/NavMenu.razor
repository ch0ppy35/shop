<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">NATS Shop</a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="products">
                <span class="bi bi-box-seam-fill" aria-hidden="true"></span> Products
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="cart">
                <span class="bi bi-cart-fill" aria-hidden="true"></span> Cart
                @if (cartItemCount > 0)
                {
                    <span class="badge bg-primary rounded-pill ms-1">@cartItemCount</span>
                }
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="admin/products">
                <span class="bi bi-gear-fill" aria-hidden="true"></span> Admin
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="about">
                <span class="bi bi-info-circle-fill" aria-hidden="true"></span> About
            </NavLink>
        </div>
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;
    private int cartItemCount = 0;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    [Inject]
    private ICartService CartService { get; set; } = default!;

    [Inject]
    private IJSRuntime JSRuntime { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        await UpdateCartItemCount();

#if !TEST
        // Listen for cart updates - skip in test environment
        try
        {
            await JSRuntime.InvokeVoidAsync("eval",
            "document.addEventListener('cartUpdated', function() { DotNet.invokeMethodAsync('Frontend', 'RefreshNavMenu'); });");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error setting up cart update listener: {ex.Message}");
        }
#endif
    }

    [JSInvokable]
    public static async Task RefreshNavMenu()
    {
        if (NavMenuInstance != null)
        {
            await NavMenuInstance.UpdateCartItemCount();
        }
    }

    private static NavMenu? NavMenuInstance;

    protected override void OnInitialized()
    {
        NavMenuInstance = this;
    }

    private async Task UpdateCartItemCount()
    {
        var cart = await CartService.GetCartAsync();
        cartItemCount = cart.ItemCount;
        StateHasChanged();
    }

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}
