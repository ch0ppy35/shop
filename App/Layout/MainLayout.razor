@inherits LayoutComponentBase
@inject SessionService SessionService
@inject IDialogService DialogService

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                       OnClick="@((e) => DrawerToggle())"/>
        <MudText Typo="Typo.h6" Class="ml-3">NATS Shop</MudText>
        <MudSpacer/>
        <MudTooltip Text="@($"Session ID: {_sessionId}")">
            <MudText Color="Color.Primary" Class="d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.Person" Class="mr-2" Size="Size.Small"/>
                <span>Session</span>
            </MudText>
        </MudTooltip>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2" Variant="DrawerVariant.Mini">
        <NavMenu DrawerOpen="_drawerOpen"/>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="my-4 pt-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private string _sessionId = "Loading...";
    private Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        await UpdateSessionIdAsync();

        // Set up a timer to refresh the session ID every 30 seconds
        _timer = new Timer(async _ =>
        {
            await UpdateSessionIdAsync();
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.Zero, TimeSpan.FromSeconds(30));
    }

    private async Task UpdateSessionIdAsync()
    {
        _sessionId = await SessionService.GetSessionIdAsync();
    }

    private void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }

    public async ValueTask DisposeAsync()
    {
        if (_timer != null)
        {
            await _timer.DisposeAsync();
            _timer = null;
        }
    }

}
