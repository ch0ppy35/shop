@page "/products/{id}"
@inject ProductService ProductService
@inject ICartService CartService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<PageTitle>Product Details</PageTitle>

@if (product == null && !loading)
{
    <div class="alert alert-warning" role="alert">
        Product not found.
    </div>
    <button class="btn btn-primary" @onclick="GoBack">Back to Products</button>
}
else if (loading)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row">
        <div class="col-md-8">
            <h1>@product?.Name</h1>
            <div class="mb-3">
                <span class="badge bg-primary">SKU: @product?.Sku</span>
                <span class="badge bg-info">@product?.QuantityInStock in stock</span>
            </div>
            <h2 class="text-primary">$@product?.Price.ToString("F2")</h2>
            <hr />
            <h3>Description</h3>
            <p>@product?.Description</p>
            <hr />
            <h3>Inventory Details</h3>
            <table class="table table-bordered">
                <tbody>
                    <tr>
                        <th>Location</th>
                        <td>@product?.Location</td>
                    </tr>
                    <tr>
                        <th>Quantity in Stock</th>
                        <td>@product?.QuantityInStock</td>
                    </tr>
                    <tr>
                        <th>Reorder Threshold</th>
                        <td>@product?.ReorderThreshold</td>
                    </tr>
                </tbody>
            </table>
            <div class="mt-4 d-flex gap-2">
                <button class="btn btn-primary" @onclick="GoBack">Back to Products</button>
                <button class="btn btn-success" @onclick="AddToCart" disabled="@(product?.QuantityInStock <= 0)">
                    <span class="bi bi-cart-plus"></span> Add to Cart
                </button>
            </div>

            @if (showQuantitySelector)
            {
                <div class="mt-3 p-3 border rounded">
                    <h4>Add to Cart</h4>
                    <div class="d-flex align-items-center gap-3">
                        <div class="input-group" style="width: 150px;">
                            <button class="btn btn-outline-secondary" type="button"
                                @onclick="() => quantity = Math.Max(1, quantity - 1)">
                                <span class="bi bi-dash"></span>
                            </button>
                            <input type="number" class="form-control text-center" @bind="quantity" min="1"
                                max="@product?.QuantityInStock" />
                            <button class="btn btn-outline-secondary" type="button"
                                @onclick="() => quantity = Math.Min(product?.QuantityInStock ?? 1, quantity + 1)">
                                <span class="bi bi-plus"></span>
                            </button>
                        </div>
                        <button class="btn btn-success" @onclick="AddToCartWithQuantity">
                            Add to Cart
                        </button>
                        <button class="btn btn-outline-secondary" @onclick="() => showQuantitySelector = false">
                            Cancel
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private Product? product;
    private bool loading = true;
    private bool showQuantitySelector = false;
    private int quantity = 1;

    protected override async Task OnInitializedAsync()
    {
        await LoadProductAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadProductAsync();
    }

    private async Task LoadProductAsync()
    {
        loading = true;
        product = await ProductService.GetProductAsync(Id);
        loading = false;
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/products");
    }

    private void AddToCart()
    {
        showQuantitySelector = true;
        quantity = 1;
    }

    private async Task AddToCartWithQuantity()
    {
        if (product == null || string.IsNullOrEmpty(product.Id))
        {
            return;
        }

        var success = await CartService.AddItemAsync(product.Id, quantity);

        if (success)
        {
#if !TEST
            try
            {
                await JSRuntime.InvokeVoidAsync("alert", $"{quantity} item(s) added to cart!");
                // Refresh the cart count in the navigation menu
                await JSRuntime.InvokeVoidAsync("cartHelper.refreshNavMenu");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error with JS interop: {ex.Message}");
            }
#endif
            showQuantitySelector = false;
        }
        else
        {
#if !TEST
            try
            {
                await JSRuntime.InvokeVoidAsync("alert", "Failed to add item to cart. Please try again.");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error showing alert: {ex.Message}");
            }
#endif
        }
    }
}
