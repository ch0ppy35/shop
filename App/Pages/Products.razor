@page "/products"
@inject ProductService ProductService
@inject ICartService CartService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject ToastService ToastService

<PageTitle>Products</PageTitle>

<MudText Typo="Typo.h3" Class="mb-4">Products</MudText>

<MudText Typo="Typo.body1" Class="mb-4">Browse our selection of products.</MudText>

@if (products == null)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (products.Items == null || !products.Items.Any())
{
    <MudAlert Severity="Severity.Info">No products found.</MudAlert>
}
else
{
    <MudGrid Spacing="4" Class="mb-8">
        @foreach (var product in products.Items)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="2" Class="h-100">
                    <MudCardContent>
                        <MudText Typo="Typo.h5"
                            Style="height: 32px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@product.Name
                        </MudText>
                        <MudText Typo="Typo.subtitle1" Color="Color.Primary">$@product.Price.ToString("F2")</MudText>
                        <MudText Typo="Typo.body2" Class="mt-3"
                            Style="height: 80px; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 4; -webkit-box-orient: vertical;">
                            @product.Description
                        </MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">
                            In Stock: @product.QuantityInStock
                        </MudText>
                    </MudCardContent>
                    <MudCardActions Class="d-flex justify-space-between">
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                            OnClick="() => NavigateToProductDetails(product.Id)">
                            View Details
                        </MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="() => AddToCart(product.Id)">
                            Add to Cart
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    </MudGrid>

    <MudPagination Count="@products.TotalPages" SelectedChanged="NavigateToPage" Selected="@products.PageNumber"
        Class="d-flex justify-center" />
}

@code {
    private PaginatedList<Product>? products;
    private int currentPage = 1;
    private const int PageSize = 9;

    protected override async Task OnInitializedAsync()
    {
        await LoadProductsAsync(currentPage);
    }

    protected override async Task OnParametersSetAsync()
    {
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        if (QueryHelpers.ParseQuery(uri.Query).TryGetValue("page", out var pageValue))
        {
            if (int.TryParse(pageValue, out var page) && page > 0)
            {
                // Only load if the page is different from the current page
                if (page != currentPage)
                {
                    currentPage = page;
                    await LoadProductsAsync(currentPage);
                }
            }
        }
        else if (currentPage != 1)
        {
            // If no page parameter is in the URL, go to page 1
            await NavigateToPage(1);
        }
    }

    private async Task LoadProductsAsync(int page)
    {
        products = await ProductService.GetProductsAsync(page, PageSize);
        currentPage = products.PageNumber;
    }

    private async Task NavigateToPage(int page)
    {
        if (page < 1 || (products != null && page > products.TotalPages))
        {
            return;
        }

        currentPage = page;
        await LoadProductsAsync(page);

        // Update the URL without causing a navigation
        var uri = NavigationManager.GetUriWithQueryParameter("page", page);
        NavigationManager.NavigateTo(uri, false);
    }

    private void NavigateToProductDetails(string? productId)
    {
        if (!string.IsNullOrEmpty(productId))
        {
            NavigationManager.NavigateTo($"/products/{productId}");
        }
    }

    private async Task AddToCart(string? productId)
    {
        if (string.IsNullOrEmpty(productId))
        {
            return;
        }

        var success = await CartService.AddItemAsync(productId);

        if (success)
        {
            ToastService.ShowSuccess("Item added to cart!");

#if !TEST
            try
            {
                // Refresh the cart count in the navigation menu
                await JSRuntime.InvokeVoidAsync("cartHelper.refreshNavMenu");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error with JS interop: {ex.Message}");
            }
#endif
        }
        else
        {
            ToastService.ShowError("Failed to add item to cart. Please try again.");
        }
    }


}
