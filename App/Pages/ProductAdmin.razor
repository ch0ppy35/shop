@page "/admin/products"
@using Microsoft.AspNetCore.WebUtilities
@using Frontend.Models
@using Frontend.Services
@using Frontend.Components
@inject ProductService ProductService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject ToastService ToastService
@inject IConfirmService ConfirmService

<PageTitle>Product Administration</PageTitle>

<MudText Typo="Typo.h3" Class="mb-4">Product Administration</MudText>

<MudText Typo="Typo.body1" Class="mb-4">Manage your product catalog.</MudText>

<div class="mb-4">
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
        OnClick="() => OpenProductModal(null)">Add New Product</MudButton>
</div>

@if (products == null)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (products.Items == null || !products.Items.Any())
{
    <MudAlert Severity="Severity.Info">No products found.</MudAlert>
}
else
{
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudTable Items="@products.Items" Hover="true" Breakpoint="Breakpoint.Sm">
            <HeaderContent>
                <MudTh>ID</MudTh>
                <MudTh>Name</MudTh>
                <MudTh>Price</MudTh>
                <MudTh>SKU</MudTh>
                <MudTh>Quantity In Stock</MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    <MudTooltip Text="@context.Id" Placement="Placement.Top" Arrow="true">
                        <MudText>@(context.Id?.Length > 8 ? context.Id.Substring(0, 8) + "..." : context.Id)</MudText>
                    </MudTooltip>
                </MudTd>
                <MudTd>@context.Name</MudTd>
                <MudTd>$@context.Price.ToString("F2")</MudTd>
                <MudTd>@context.Sku</MudTd>
                <MudTd>@context.QuantityInStock</MudTd>
                <MudTd>
                    <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small">
                        <MudButton Color="Color.Primary" OnClick="() => OpenProductModal(context)">
                            <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-1" Size="Size.Small" /> Edit
                        </MudButton>
                        <MudButton Color="Color.Error" OnClick="async () => await ConfirmDelete(context)">
                            <MudIcon Icon="@Icons.Material.Filled.Delete" Class="mr-1" Size="Size.Small" /> Delete
                        </MudButton>
                    </MudButtonGroup>
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>

    <div class="d-flex justify-center mt-4">
        <MudPagination Count="@products.TotalPages" SelectedChanged="NavigateToPage" Selected="@products.PageNumber" />
    </div>
}

<MudDialog Visible="showProductModal" Options="dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Inventory" Class="mr-3" />
            @(editingProduct.Id == null ? "Add New Product" : "Edit Product")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm Model="@editingProduct" @ref="form" @bind-IsValid="@success">
            <MudGrid>
                <MudItem xs="12">
                    <MudTextField @bind-Value="editingProduct.Name" Label="Name" Required="true"
                        RequiredError="Name is required" />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="editingProduct.Description" Label="Description" Lines="3" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="editingProduct.Price" Label="Price" Adornment="Adornment.Start"
                        AdornmentIcon="@Icons.Material.Filled.AttachMoney" InputType="InputType.Number" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="editingProduct.Sku" Label="SKU" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="editingProduct.Location" Label="Location" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="editingProduct.QuantityInStock" Label="Quantity In Stock"
                        InputType="InputType.Number" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="editingProduct.ReorderThreshold" Label="Reorder Threshold"
                        InputType="InputType.Number" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseProductModal" Variant="Variant.Outlined" Color="Color.Secondary">Cancel</MudButton>
        <MudButton OnClick="SaveProduct" Variant="Variant.Filled" Color="Color.Primary" Disabled="!success">Save
        </MudButton>
    </DialogActions>
</MudDialog>



@code {
    private PaginatedList<Product>? products;
    private int currentPage = 1;
    private const int PageSize = 10;
    private bool showProductModal = false;
    private Product editingProduct = new();
    private Product? productToDelete;
    private MudForm? form;
    private bool success;
    private DialogOptions dialogOptions = new()
    {
        FullWidth = true,
        MaxWidth = MaxWidth.Medium,
        CloseButton = true
    };



    protected override async Task OnInitializedAsync()
    {
        await LoadProductsAsync(currentPage);
    }

    protected override async Task OnParametersSetAsync()
    {
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        if (QueryHelpers.ParseQuery(uri.Query).TryGetValue("page", out var pageValue))
        {
            if (int.TryParse(pageValue, out var page) && page > 0)
            {
                // Only load if the page is different from the current page
                if (page != currentPage)
                {
                    currentPage = page;
                    await LoadProductsAsync(currentPage);
                }
            }
        }
        else if (currentPage != 1)
        {
            // If no page parameter is in the URL, go to page 1
            await NavigateToPage(1);
        }
    }

    private async Task LoadProductsAsync(int page)
    {
        products = await ProductService.GetProductsAsync(page, PageSize);
        currentPage = products.PageNumber;
    }

    private async Task NavigateToPage(int page)
    {
        if (page < 1 || (products != null && page > products.TotalPages))
        {
            return;
        }

        currentPage = page;
        await LoadProductsAsync(page);

        // Update the URL without causing a navigation
        var uri = NavigationManager.GetUriWithQueryParameter("page", page);
        NavigationManager.NavigateTo(uri, false);
    }

    private void OpenProductModal(Product? product)
    {
        if (product == null)
        {
            // Creating a new product
            editingProduct = new Product();
        }
        else
        {
            // Editing an existing product - create a copy to avoid modifying the original
            editingProduct = new Product
            {
                Id = product.Id,
                Name = product.Name,
                Description = product.Description,
                Price = product.Price,
                // Quantity field removed - using QuantityInStock instead
                Sku = product.Sku,
                Location = product.Location,
                QuantityInStock = product.QuantityInStock,
                ReorderThreshold = product.ReorderThreshold
            };
        }

        showProductModal = true;
    }

    private void CloseProductModal()
    {
        showProductModal = false;
    }

    private async Task SaveProduct()
    {
        if (string.IsNullOrEmpty(editingProduct.Id))
        {
            // Create new product
            var createdProduct = await ProductService.CreateProductAsync(editingProduct);
            if (createdProduct != null)
            {
                ToastService.ShowSuccess("Product created successfully!");
            }
            else
            {
                ToastService.ShowError("Failed to create product. Please try again.");
            }
        }
        else
        {
            // Update existing product
            var success = await ProductService.UpdateProductAsync(editingProduct);
            if (success)
            {
                ToastService.ShowSuccess("Product updated successfully!");
            }
            else
            {
                ToastService.ShowError("Failed to update product. Please try again.");
            }
        }

        // Close the modal and refresh the product list
        CloseProductModal();
        await LoadProductsAsync(currentPage);
    }

    private async Task ConfirmDelete(Product product)
    {
        productToDelete = product;
        var confirmed = await ConfirmService.ShowConfirmation(
        $"Are you sure you want to delete the product \"{product.Name}\"?",
        "Delete Product",
        "Danger",
        "Delete");

        if (confirmed)
        {
            await DeleteProduct();
        }
    }

    private async Task DeleteProduct()
    {
        if (productToDelete != null)
        {
            var success = await ProductService.DeleteProductAsync(productToDelete.Id!);
            if (success)
            {
                ToastService.ShowSuccess("Product deleted successfully!");
            }
            else
            {
                ToastService.ShowError("Failed to delete product. Please try again.");
            }

            // Refresh the product list
            await LoadProductsAsync(currentPage);
        }
    }
}
