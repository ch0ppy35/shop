@page "/admin/products"
@using Microsoft.AspNetCore.WebUtilities
@using Frontend.Models
@using Frontend.Services
@using Frontend.Components
@inject ProductService ProductService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject ToastService ToastService
@inject IConfirmService ConfirmService

<PageTitle>Product Administration</PageTitle>

<h1>Product Administration</h1>

<p>Manage your product catalog.</p>

<div class="mb-3">
    <button class="btn btn-primary" @onclick="() => OpenProductModal(null)">Add New Product</button>
</div>

@if (products == null)
{
    <p><em>Loading...</em></p>
}
else if (products.Items == null || !products.Items.Any())
{
    <p>No products found.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Price</th>
                    <th>SKU</th>
                    <th>Quantity In Stock</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in products.Items)
                {
                    <tr>
                        <td>
                            <Tooltip Content="@(product.Id?.Length > 8 ? product.Id.Substring(0, 8) + "..." : product.Id)"
                                TooltipText="@product.Id" Position="top" Width="auto" />
                        </td>
                        <td>@product.Name</td>
                        <td>$@product.Price.ToString("F2")</td>
                        <td>@product.Sku</td>
                        <td>@product.QuantityInStock</td>
                        <td>
                            <div class="btn-group" role="group">
                                <button class="btn btn-sm btn-primary" @onclick="() => OpenProductModal(product)">Edit</button>
                                <button class="btn btn-sm btn-outline-danger"
                                    @onclick="async () => await ConfirmDelete(product)">Delete</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">
            <li class="page-item @(products.HasPreviousPage ? "" : "disabled")">
                <button class="page-link" @onclick="() => NavigateToPage(products.PageNumber - 1)"
                    disabled="@(!products.HasPreviousPage)" aria-label="Previous">
                    <span aria-hidden="true">&laquo;</span>
                </button>
            </li>

            @for (int i = 1; i <= products.TotalPages; i++)
            {
                var pageNumber = i;
                <li class="page-item @(pageNumber == products.PageNumber ? "active" : "")">
                    <button class="page-link" @onclick="() => NavigateToPage(pageNumber)">@pageNumber</button>
                </li>
            }

            <li class="page-item @(products.HasNextPage ? "" : "disabled")">
                <button class="page-link" @onclick="() => NavigateToPage(products.PageNumber + 1)"
                    disabled="@(!products.HasNextPage)" aria-label="Next">
                    <span aria-hidden="true">&raquo;</span>
                </button>
            </li>
        </ul>
    </nav>
}

<!-- Product Modal -->
@if (showProductModal)
{
    <div class="modal fade show" style="display: block;" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(editingProduct.Id == null ? "Add New Product" : "Edit Product")</h5>
                    <button type="button" class="btn-close" @onclick="CloseProductModal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="@editingProduct" OnValidSubmit="SaveProduct">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="mb-3">
                            <label for="name" class="form-label">Name</label>
                            <InputText id="name" class="form-control" @bind-Value="editingProduct.Name" />
                        </div>

                        <div class="mb-3">
                            <label for="description" class="form-label">Description</label>
                            <InputTextArea id="description" class="form-control" @bind-Value="editingProduct.Description"
                                rows="3" />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="price" class="form-label">Price</label>
                                <InputNumber id="price" class="form-control" @bind-Value="editingProduct.Price" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="sku" class="form-label">SKU</label>
                                <InputText id="sku" class="form-control" @bind-Value="editingProduct.Sku" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="location" class="form-label">Location</label>
                                <InputText id="location" class="form-control" @bind-Value="editingProduct.Location" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="quantityInStock" class="form-label">Quantity In Stock</label>
                                <InputNumber id="quantityInStock" class="form-control"
                                    @bind-Value="editingProduct.QuantityInStock" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="reorderThreshold" class="form-label">Reorder Threshold</label>
                                <InputNumber id="reorderThreshold" class="form-control"
                                    @bind-Value="editingProduct.ReorderThreshold" />
                            </div>
                        </div>

                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" @onclick="CloseProductModal">Cancel</button>
                            <button type="submit" class="btn btn-primary">Save</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}



@code {
    private PaginatedList<Product>? products;
    private int currentPage = 1;
    private const int PageSize = 10;
    private bool showProductModal = false;
    private Product editingProduct = new();
    private Product? productToDelete;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Initialize Bootstrap tooltips
            await JSRuntime.InvokeVoidAsync("initTooltips");
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadProductsAsync(currentPage);
    }

    protected override async Task OnParametersSetAsync()
    {
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        if (QueryHelpers.ParseQuery(uri.Query).TryGetValue("page", out var pageValue))
        {
            if (int.TryParse(pageValue, out var page) && page > 0)
            {
                // Only load if the page is different from the current page
                if (page != currentPage)
                {
                    currentPage = page;
                    await LoadProductsAsync(currentPage);
                }
            }
        }
        else if (currentPage != 1)
        {
            // If no page parameter is in the URL, go to page 1
            await NavigateToPage(1);
        }
    }

    private async Task LoadProductsAsync(int page)
    {
        products = await ProductService.GetProductsAsync(page, PageSize);
        currentPage = products.PageNumber;
    }

    private async Task NavigateToPage(int page)
    {
        if (page < 1 || (products != null && page > products.TotalPages))
        {
            return;
        }

        currentPage = page;
        await LoadProductsAsync(page);

        // Update the URL without causing a navigation
        var uri = NavigationManager.GetUriWithQueryParameter("page", page);
        NavigationManager.NavigateTo(uri, false);
    }

    private void OpenProductModal(Product? product)
    {
        if (product == null)
        {
            // Creating a new product
            editingProduct = new Product();
        }
        else
        {
            // Editing an existing product - create a copy to avoid modifying the original
            editingProduct = new Product
            {
                Id = product.Id,
                Name = product.Name,
                Description = product.Description,
                Price = product.Price,
                // Quantity field removed - using QuantityInStock instead
                Sku = product.Sku,
                Location = product.Location,
                QuantityInStock = product.QuantityInStock,
                ReorderThreshold = product.ReorderThreshold
            };
        }

        showProductModal = true;
    }

    private void CloseProductModal()
    {
        showProductModal = false;
    }

    private async Task SaveProduct()
    {
        if (string.IsNullOrEmpty(editingProduct.Id))
        {
            // Create new product
            var createdProduct = await ProductService.CreateProductAsync(editingProduct);
            if (createdProduct != null)
            {
                ToastService.ShowSuccess("Product created successfully!");
            }
            else
            {
                ToastService.ShowError("Failed to create product. Please try again.");
            }
        }
        else
        {
            // Update existing product
            var success = await ProductService.UpdateProductAsync(editingProduct);
            if (success)
            {
                ToastService.ShowSuccess("Product updated successfully!");
            }
            else
            {
                ToastService.ShowError("Failed to update product. Please try again.");
            }
        }

        // Close the modal and refresh the product list
        CloseProductModal();
        await LoadProductsAsync(currentPage);
    }

    private async Task ConfirmDelete(Product product)
    {
        productToDelete = product;
        var confirmed = await ConfirmService.ShowConfirmation(
        $"Are you sure you want to delete the product \"{product.Name}\"?",
        "Delete Product",
        "Danger",
        "Delete");

        if (confirmed)
        {
            await DeleteProduct();
        }
    }

    private async Task DeleteProduct()
    {
        if (productToDelete != null)
        {
            var success = await ProductService.DeleteProductAsync(productToDelete.Id!);
            if (success)
            {
                ToastService.ShowSuccess("Product deleted successfully!");
            }
            else
            {
                ToastService.ShowError("Failed to delete product. Please try again.");
            }

            // Refresh the product list
            await LoadProductsAsync(currentPage);
        }
    }
}
