@page "/about"

<PageTitle>About NATS Shop</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
    <MudText Typo="Typo.h3" Class="mb-6">About NATS Shop</MudText>

    <MudGrid Class="mt-6">
        <MudItem xs="12" md="8">
            <MudPaper Elevation="0" Class="pa-4">
                <MudText Typo="Typo.h5" Class="mb-4">Project Overview</MudText>
                <MudText Typo="Typo.body1" Class="mb-6">
                    NATS Shop is a demonstration of a modern microservice-based e-commerce application built with .NET
                    9.0.
                    It showcases how to build scalable, resilient, and maintainable web applications using a
                    microservice architecture.
                </MudText>

                <MudText Typo="Typo.h6" Class="mt-6 mb-3">Key Features</MudText>
                <MudPaper Elevation="0" Class="pa-0">
                    <div class="d-flex align-center mb-2">
                        <MudIcon Icon="@Icons.Material.Filled.Architecture" Class="mr-2"/>
                        <MudText>Microservice Architecture - Separate services for products, with clear boundaries and
                            responsibilities
                        </MudText>
                    </div>
                    <div class="d-flex align-center mb-2">
                        <MudIcon Icon="@Icons.Material.Filled.Send" Class="mr-2"/>
                        <MudText>NATS Messaging - Using NATS as a lightweight, high-performance messaging system for
                            service communication
                        </MudText>
                    </div>
                    <div class="d-flex align-center mb-2">
                        <MudIcon Icon="@Icons.Material.Filled.Reply" Class="mr-2"/>
                        <MudText>Request/Reply Pattern - Implementing synchronous communication between services
                        </MudText>
                    </div>
                    <div class="d-flex align-center mb-2">
                        <MudIcon Icon="@Icons.Material.Filled.Storage" Class="mr-2"/>
                        <MudText>PostgreSQL Database - Storing product and inventory data in a relational database
                        </MudText>
                    </div>
                    <div class="d-flex align-center mb-2">
                        <MudIcon Icon="@Icons.Material.Filled.DataObject" Class="mr-2"/>
                        <MudText>Entity Framework Core - Using EF Core for database access and migrations</MudText>
                    </div>
                    <div class="d-flex align-center mb-2">
                        <MudIcon Icon="@Icons.Material.Filled.Web" Class="mr-2"/>
                        <MudText>Blazor WebAssembly App - Modern, component-based UI running in the browser
                        </MudText>
                    </div>
                    <div class="d-flex align-center mb-2">
                        <MudIcon Icon="@Icons.Material.Filled.ViewInAr" Class="mr-2"/>
                        <MudText>Docker Containerization - Packaging the application for consistent deployment</MudText>
                    </div>
                    <div class="d-flex align-center mb-2">
                        <MudIcon Icon="@Icons.Material.Filled.HealthAndSafety" Class="mr-2"/>
                        <MudText>Health Monitoring - Implementing health checks for services</MudText>
                    </div>
                </MudPaper>

                <MudText Typo="Typo.h6" Class="mt-6 mb-3">Architecture</MudText>
                <MudText Typo="Typo.body1" Class="mb-3">
                    The application follows a microservice architecture with the following components:
                </MudText>
                <MudPaper Elevation="0" Class="pa-0">
                    <div class="d-flex align-center mb-2">
                        <MudIcon Icon="@Icons.Material.Filled.Devices" Class="mr-2"/>
                        <MudText>App - Blazor WebAssembly application that provides the user interface</MudText>
                    </div>
                    <div class="d-flex align-center mb-2">
                        <MudIcon Icon="@Icons.Material.Filled.Hub" Class="mr-2"/>
                        <MudText>API Gateway - Entry point for all client requests, routing them to appropriate
                            services
                        </MudText>
                    </div>
                    <div class="d-flex align-center mb-2">
                        <MudIcon Icon="@Icons.Material.Filled.Inventory" Class="mr-2"/>
                        <MudText>Products Service - Manages product data and inventory</MudText>
                    </div>
                    <div class="d-flex align-center mb-2">
                        <MudIcon Icon="@Icons.Material.Filled.SwapHoriz" Class="mr-2"/>
                        <MudText>NATS Server - Message broker for service communication</MudText>
                    </div>
                    <div class="d-flex align-center mb-2">
                        <MudIcon Icon="@Icons.Material.Filled.Storage" Class="mr-2"/>
                        <MudText>PostgreSQL Database - Persistent storage for product data</MudText>
                    </div>
                </MudPaper>

                <MudText Typo="Typo.h6" Class="mt-6 mb-3">Technologies Used</MudText>
                <div class="d-flex flex-wrap gap-2">
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" Class="rounded-pill"
                               Style="text-transform: none;">.NET 9.0
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" Class="rounded-pill"
                               Style="text-transform: none;">ASP.NET Core
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" Class="rounded-pill"
                               Style="text-transform: none;">Blazor WebAssembly
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" Class="rounded-pill"
                               Style="text-transform: none;">Entity Framework Core
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" Class="rounded-pill"
                               Style="text-transform: none;">NATS
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" Class="rounded-pill"
                               Style="text-transform: none;">PostgreSQL
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" Class="rounded-pill"
                               Style="text-transform: none;">Docker
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" Class="rounded-pill"
                               Style="text-transform: none;">MudBlazor
                    </MudButton>
                </div>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudCard Elevation="3">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Project Information</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <div>
                        <MudText Class="d-flex align-center mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.Tag" Class="mr-2" Size="Size.Small"/>
                            <span>Version: 1.0.0</span>
                        </MudText>
                        <MudText Class="d-flex align-center mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.Code" Class="mr-2" Size="Size.Small"/>
                            <span>Framework: .NET 9.0</span>
                        </MudText>
                        <MudText Class="d-flex align-center mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.Web" Class="mr-2" Size="Size.Small"/>
                            <span>App: Blazor WebAssembly</span>
                        </MudText>
                        <MudText Class="d-flex align-center mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.Api" Class="mr-2" Size="Size.Small"/>
                            <span>Backend: ASP.NET Core Microservices</span>
                        </MudText>
                        <MudText Class="d-flex align-center mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.Storage" Class="mr-2" Size="Size.Small"/>
                            <span>Database: PostgreSQL</span>
                        </MudText>
                        <MudText Class="d-flex align-center mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.Send" Class="mr-2" Size="Size.Small"/>
                            <span>Messaging: NATS</span>
                        </MudText>
                    </div>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
</MudContainer>
