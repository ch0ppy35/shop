            Background = "#121212",
            Surface = "#1E1E2D",
            DrawerBackground = "#1E1E2D",
            DrawerText = "rgba(255,255,255, 0.8)",
            DrawerIcon = "rgba(255,255,255, 0.8)",
            Success = "#10B981",
            Error = "#EF4444",
            Warning = "#F59E0B",
            Info = "#3B82F6",
            TextPrimary = "rgba(255,255,255, 0.9)",
