@implements IDisposable
@inject ToastService ToastService

<Toast @ref="toastComponent" />

@code {
    private Toast? toastComponent;

    protected override void OnInitialized()
    {
        ToastService.OnShow += ShowToast;
    }

    private void ShowToast(string message, string title, string type, int autoHideDelayMs)
    {
        var toastType = Enum.Parse<Toast.ToastType>(type);
        toastComponent?.Show(message, title, toastType, autoHideDelayMs);
    }

    public void Dispose()
    {
        ToastService.OnShow -= ShowToast;
    }
}
